@using BlindMatchPAS.Models
@model IEnumerable<BlindMatchPAS.Models.ProjectViewModel>

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>NSBM Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body class="bg-[#f8fafc] font-sans text-slate-900">
    <div class="flex h-screen overflow-hidden">

        <aside class="w-64 bg-[#1a222e] text-slate-400 flex flex-col shrink-0">
            <div class="p-6 flex items-center gap-3 text-white">
                <span class="text-xl font-bold uppercase">NSBM</span>
            </div>
            <nav class="flex-1 px-4 space-y-1 mt-4 text-sm">
                <a asp-controller="Student" asp-action="Index" class="flex items-center gap-3 p-3 text-white bg-slate-800/50 rounded-lg">
                    <i class="fa-solid fa-house w-5"></i> Dashboard
                </a>
                <a asp-controller="Student" asp-action="SubmitProject" class="flex items-center gap-3 p-3 hover:text-white transition-colors">
                    <i class="fa-solid fa-plus w-5"></i> Submit New Project
                </a>
            </nav>
        </aside>

        <main class="flex-1 flex flex-col min-w-0">
            <div class="p-8">
                <div class="flex justify-between items-center mb-8">
                    <a asp-controller="Student" asp-action="SubmitProject"
                       class="bg-[#22c55e] text-white px-6 py-2 rounded-md font-semibold text-sm no-underline shadow-sm hover:bg-emerald-600 transition-colors">
                        Submit New Project
                    </a>
                </div>

                <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <table class="w-full text-left">
                        <thead class="bg-slate-50 text-slate-400 text-[11px] uppercase font-bold">
                            <tr>
                                <th class="px-6 py-4">Project Title</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Submitted Date</th>
                                <th class="px-6 py-4 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @foreach (var item in Model)
                            {
                                <tr class="hover:bg-slate-50 transition-colors">
                                    <td class="px-6 py-4 text-sm font-medium text-slate-700">@item.Title</td>
                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded text-[10px] font-bold uppercase border
                                            @(item.Status == "Pending" ? "bg-amber-50 text-amber-600 border-amber-100" : "bg-emerald-50 text-emerald-600 border-emerald-100")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-3 py-1 rounded text-[10px] font-bold text-blue-600 bg-blue-50 border-blue-100">
                                            @item.SubmittedAt.ToString("yyyy-MM-dd")
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-center">
                                        <button class="bg-[#22c55e] hover:bg-emerald-600 text-white px-4 py-1.5 rounded text-[10px] font-bold transition-colors">
                                            View
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</body>
</html>
@model IEnumerable<BlindMatchPAS.Models.ProjectViewModel>
@{
    ViewData["Title"] = "Student Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NSBM Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body class="bg-[#f8fafc] font-sans text-slate-900">
    <div class="flex h-screen overflow-hidden">

        <aside class="w-64 bg-[#1a222e] text-slate-400 flex flex-col shrink-0">
            <div class="p-6 flex items-center gap-3 text-white">
                <span class="text-xl font-bold uppercase">NSBM</span>
            </div>
            <nav class="flex-1 px-4 space-y-1 mt-4 text-sm">
                <a asp-controller="Student" asp-action="Index"
                   class="flex items-center gap-3 p-3 text-white bg-slate-800/50 rounded-lg">
                    <i class="fa-solid fa-house w-5"></i> Dashboard
                </a>
                <a asp-controller="Student" asp-action="SubmitProject"
                   class="flex items-center gap-3 p-3 hover:text-white transition-colors">
                    <i class="fa-solid fa-plus w-5"></i> Submit New Project
                </a>
                <a asp-controller="Account" asp-action="Logout"
                   class="flex items-center gap-3 p-3 hover:text-white transition-colors text-red-400">
                    <i class="fa-solid fa-right-from-bracket w-5"></i> Logout
                </a>
            </nav>
        </aside>

        <main class="flex-1 flex flex-col min-w-0">
            <div class="p-8">
                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h2 class="text-2xl font-bold text-slate-800">Student Dashboard</h2>
                        <p class="text-slate-500 mt-1">Welcome, <strong>@ViewBag.StudentName</strong></p>
                    </div>
                    <a asp-controller="Student" asp-action="SubmitProject"
                       class="bg-[#22c55e] text-white px-6 py-2 rounded-md font-semibold text-sm no-underline shadow-sm hover:bg-emerald-600 transition-colors">
                        Submit New Project
                    </a>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
                        <i class="fa-solid fa-check-circle mr-2"></i> @TempData["SuccessMessage"]
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
                        <i class="fa-solid fa-exclamation-circle mr-2"></i> @TempData["ErrorMessage"]
                    </div>
                }

                @if (!Model.Any())
                {
                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-12 text-center">
                        <i class="fa-solid fa-folder-open text-slate-300 text-6xl mb-4"></i>
                        <h4 class="text-slate-500 font-semibold">No Projects Submitted Yet</h4>
                        <p class="text-slate-400 text-sm mt-2">Click "Submit New Project" to get started.</p>
                    </div>
                }
                else
                {
                    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                        <table class="w-full text-left">
                            <thead class="bg-slate-50 text-slate-400 text-[11px] uppercase font-bold">
                                <tr>
                                    <th class="px-6 py-4">Project Title</th>
                                    <th class="px-6 py-4">Research Area</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4">Submitted Date</th>
                                    <th class="px-6 py-4">Supervisor (After Match)</th>
                                    <th class="px-6 py-4 text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                @foreach (var item in Model)
                                {
                                    <tr class="hover:bg-slate-50 transition-colors">
                                        <td class="px-6 py-4 text-sm font-medium text-slate-700">@item.Title</td>
                                        <td class="px-6 py-4">
                                            <span class="px-2 py-1 rounded text-[10px] font-bold uppercase bg-blue-50 text-blue-600 border border-blue-100">
                                                @item.ResearchArea
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-3 py-1 rounded text-[10px] font-bold uppercase border
                                                @(item.Status == "Pending" ? "bg-amber-50 text-amber-600 border-amber-100" :
                                                  item.Status == "Matched" ? "bg-emerald-50 text-emerald-600 border-emerald-100" :
                                                  item.Status == "Withdrawn" ? "bg-red-50 text-red-600 border-red-100" :
                                                  "bg-blue-50 text-blue-600 border-blue-100")">
                                                @item.Status
                                            </span>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-3 py-1 rounded text-[10px] font-bold text-blue-600 bg-blue-50 border-blue-100">
                                                @item.SubmittedAt.ToString("yyyy-MM-dd")
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-sm">
                                            @if (item.Status == "Matched" && item.SupervisorName != null)
                                            {
                                                <div>
                                                    <div class="font-semibold text-slate-700">@item.SupervisorName</div>
                                                    <div class="text-xs text-slate-400">@item.SupervisorEmail</div>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400 text-xs italic">Identity hidden until matched</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            @if (item.Status == "Pending" || item.Status == "UnderReview")
                                            {
                                                <div class="flex gap-2 justify-center">
                                                    <a asp-controller="Student" asp-action="EditProject" asp-route-id="@item.Id"
                                                       class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-1.5 rounded text-[10px] font-bold transition-colors no-underline">
                                                        Edit
                                                    </a>
                                                    <form asp-controller="Student" asp-action="WithdrawProject" asp-route-id="@item.Id" method="post" class="d-inline">
                                                        <button type="submit"
                                                                onclick="return confirm('Are you sure you want to withdraw this project?')"
                                                                class="bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded text-[10px] font-bold transition-colors border-0">
                                                            Withdraw
                                                        </button>
                                                    </form>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-slate-400 text-xs italic">@item.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </main>
    </div>
</body>
</html>
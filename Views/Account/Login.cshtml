@{
    ViewData["Title"] = "Login"; Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page-body">
    <div class="login-card-custom p-4" style="max-width: 400px; width: 100%;">
        <a asp-controller="Home" asp-action="Index"
           class="text-muted text-decoration-none small mb-3 d-inline-block">
            <i class="bi bi-arrow-left"></i> Back to Welcome
        </a>
        <div class="text-center mb-4 mt-2">
            <h2 class="fw-bold">
                <i class="bi bi-stack text-success"></i> PAS Login
            </h2>
        </div>

        @* Show success message from registration *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success py-2 small mb-3">
                <i class="bi bi-check-circle me-1"></i> @TempData["SuccessMessage"]
            </div>
        }

        @* Show validation errors *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2 small mb-3">
                @Html.ValidationSummary(true, "")
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">

            <div class="mb-3">
                <label class="form-label fw-bold">Email</label>
                <input type="email"
                       name="Email"
                       class="form-control bg-light"
                       placeholder="you@supervisor.nsbm.ac.lk"
                       required>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Password</label>
                <div class="input-group">
                    <input type="password"
                           name="Password"
                           class="form-control bg-light"
                           id="passwordInput"
                           placeholder="Enter your password"
                           required>
                    <span class="input-group-text bg-light"
                          style="cursor:pointer;"
                          onclick="togglePassword()">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="btn btn-pas-green w-100 fw-bold py-2 mb-3">
                Login
            </button>

            <div class="text-center">
                <span class="text-muted">Don't have an account? </span>
                <a asp-controller="Account" asp-action="Register"
                   class="text-success fw-bold text-decoration-none">
                    Create one
                </a>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page-body">

    <div class="login-card-custom" style="max-width: 420px; width: 100%;">
        
        <a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none small mb-3 d-inline-block">
            <i class="bi bi-arrow-left"></i> Back to Welcome
        </a>

        <div class="text-center mb-4 mt-2">
            <h2 class="fw-bold text-dark"><i class="bi bi-stack text-success"></i> PAS Login</h2>
        </div>
        
        <form asp-controller="Account" asp-action="Login" method="post">
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 small border-0 shadow-sm rounded-3">
                    @Html.ValidationSummary(true, "")
                </div>
            }

            <div class="mb-3">
                <label class="form-label fw-bold text-muted small">Academic Email</label>
                <input type="email" name="Email" class="form-control" placeholder="Username@student.ac.nsbm.lk" required>
            </div>
            
            <div class="mb-4">
                <label class="form-label fw-bold text-muted small">Password</label>
                <div class="input-group">
                    <input type="password" name="Password" class="form-control" placeholder="Enter password" required>
                    <span class="input-group-text bg-white border-start-0 text-muted cursor-pointer"><i class="bi bi-eye"></i></span>
                </div>
            </div>
            
            <button type="submit" class="btn btn-login-theme w-100 fw-bold py-2 mb-4">Login to Dashboard</button>
            
            <div class="text-center">
                <span class="text-muted small">Don't have an account? </span>
                <a asp-controller="Account" asp-action="Register" class="fw-bold text-decoration-none" style="color: #2c3e50;">Create one</a>
            </div>
        </form>
    </div>

</body>
</html>
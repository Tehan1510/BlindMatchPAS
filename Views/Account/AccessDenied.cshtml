@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-page-body">
    <div class="login-card-custom p-5 text-center" style="max-width: 450px; width: 100%;">
        <div class="mb-4">
            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 3rem;"></i>
        </div>
        <h3 class="fw-bold text-dark mb-2">Access Denied</h3>
        <p class="text-muted mb-4">
            You do not have permission to view this page.
            This area is restricted to authorized roles only.
        </p>
        <div class="alert alert-warning rounded-3 text-start small mb-4">
            <i class="bi bi-exclamation-triangle me-2"></i>
            <strong>Security Notice:</strong> This access attempt has been
            blocked by the Role-Based Access Control system.
        </div>
        <div class="d-flex flex-column gap-2">
            <a asp-controller="Account" asp-action="Logout"
               class="btn btn-pas-green rounded-pill fw-bold">
                <i class="bi bi-box-arrow-right me-2"></i> Logout & Switch Account
            </a>
            <a asp-controller="Home" asp-action="Index"
               class="btn btn-light rounded-pill border">
                <i class="bi bi-house me-2"></i> Go to Home
            </a>
        </div>
    </div>
</body>
</html>
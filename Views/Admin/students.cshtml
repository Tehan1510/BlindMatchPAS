@model IEnumerable<BlindMatchPAS.Models.UserManagementViewModel>
@{
    ViewData["Title"] = "Student Management";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body data-theme="light">
    <div class="sidebar">
        <h3><i class="bi bi-stack me-2"></i>PAS</h3>
        <ul>
            <li><a asp-controller="Admin" asp-action="Admin"><i class="bi bi-house-door me-2"></i> Dashboard</a></li>
            <li><a asp-controller="Admin" asp-action="Students"><i class="bi bi-people me-2"></i> Students</a></li>
            <li><a asp-controller="Admin" asp-action="Supervisors"><i class="bi bi-mortarboard me-2"></i> Supervisors</a></li>
            <li><a asp-controller="Admin" asp-action="Matches"><i class="bi bi-folder-check me-2"></i> Matches</a></li>
            <li><a asp-controller="Admin" asp-action="Research"><i class="bi bi-journal-text me-2"></i> Research</a></li>
            <li class="px-3"><hr style="border-top: 1px solid rgba(255,255,255,0.1);"></li>
            <li><a asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i> Settings</a></li>
        </ul>
    </div>
    <header class="topbar">
        <input type="text" class="form-control" style="max-width: 350px; border-radius: 20px;" placeholder="Search..." />
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-pill">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </div>
    </header>
    <main class="main-content">
        <div class="card-box">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0"><i class="bi bi-people me-2"></i> Student Management</h3>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="text-muted small text-uppercase">
                        <tr>
                            <th class="ps-3">ID</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Registered</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var student in Model)
                            {
                                <tr>
                                    <td class="ps-3 text-muted">#@student.Id</td>
                                    <td class="fw-bold">@student.FullName</td>
                                    <td>@student.Email</td>
                                    <td>@student.CreatedAt.ToString("yyyy-MM-dd")</td>
                                    <td class="text-end pe-3">
                                        <form asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@student.Id" method="post" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Are you sure you want to remove this student?')">
                                                Remove
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No students registered yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.body.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>
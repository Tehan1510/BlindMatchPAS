@model IEnumerable<BlindMatchPAS.Models.AdminMatchViewModel>
@{
    ViewData["Title"] = "Project Matches";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body data-theme="light">
    <div class="sidebar">
        <h3><i class="bi bi-stack me-2"></i>PAS</h3>
        <ul>
            <li><a asp-controller="Admin" asp-action="Admin"><i class="bi bi-house-door me-2"></i> Dashboard</a></li>
            <li><a asp-controller="Admin" asp-action="Students"><i class="bi bi-people me-2"></i> Students</a></li>
            <li><a asp-controller="Admin" asp-action="Supervisors"><i class="bi bi-mortarboard me-2"></i> Supervisors</a></li>
            <li><a asp-controller="Admin" asp-action="Matches"><i class="bi bi-folder-check me-2"></i> Matches</a></li>
            <li><a asp-controller="Admin" asp-action="Research"><i class="bi bi-journal-text me-2"></i> Research</a></li>
            <li class="px-3"><hr style="border-top: 1px solid rgba(255,255,255,0.1);"></li>
            <li><a asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i> Settings</a></li>
        </ul>
    </div>
    <header class="topbar">
        <input type="text" class="form-control" style="max-width: 350px; border-radius: 20px;" placeholder="Search dashboard..." />
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-pill">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </div>
    </header>
    <main class="main-content">
        <div class="card-box shadow-sm border-0 rounded-4 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0"><i class="bi bi-folder-check me-2"></i>Project Matches</h3>
                <a asp-controller="Admin" asp-action="Admin" class="btn btn-custom px-4 fw-bold shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Match ID</th>
                            <th>Student Name</th>
                            <th>Project Title</th>
                            <th>Assigned Supervisor</th>
                            <th>Research Area</th>
                            <th class="text-end pe-4">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int i = 1;
                            @foreach (var match in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@(i++)</td>
                                    <td><div class="fw-bold">@match.StudentName</div></td>
                                    <td>@match.ProjectTitle</td>
                                    <td>@match.SupervisorName</td>
                                    <td><span class="tag m-0 text-muted border-0">@match.ResearchArea</span></td>
                                    <td class="text-end pe-4">
                                        <span class="badge @(match.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark")">
                                            @match.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">No matches in the system yet.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.body.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>
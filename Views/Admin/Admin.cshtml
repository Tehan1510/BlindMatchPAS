@model IEnumerable<BlindMatchPAS.Models.AdminMatchViewModel>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body data-theme="light">
    <div class="sidebar">
        <h3><i class="bi bi-stack me-2"></i>PAS</h3>
        <ul>
            <li><a asp-controller="Admin" asp-action="Admin"><i class="bi bi-house-door me-2"></i> Dashboard</a></li>
            <li><a asp-controller="Admin" asp-action="Students"><i class="bi bi-people me-2"></i> Students</a></li>
            <li><a asp-controller="Admin" asp-action="Supervisors"><i class="bi bi-mortarboard me-2"></i> Supervisors</a></li>
            <li><a asp-controller="Admin" asp-action="Matches"><i class="bi bi-folder-check me-2"></i> Matches</a></li>
            <li><a asp-controller="Admin" asp-action="Research"><i class="bi bi-journal-text me-2"></i> Research</a></li>
            <li class="px-3"><hr style="border-top: 1px solid rgba(255,255,255,0.1);"></li>
            <li><a asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i> Settings</a></li>
        </ul>
    </div>
    <header class="topbar">
        <input type="text" class="form-control" style="max-width: 350px; border-radius: 20px;" placeholder="Search dashboard..." />
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted fw-bold">System Admin</span>
            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-pill">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </div>
    </header>
    <main class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">Admin Dashboard</h2>
                <p class="text-muted">Overview of all system activity.</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i><strong>Success!</strong> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card-box mb-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="m-0 fw-bold"><i class="bi bi-grid-1x2 me-2"></i>Overview of All Matches</h5>
                <a asp-controller="Admin" asp-action="Matches" class="btn btn-custom fw-bold shadow-sm">View Full Details</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="text-muted small text-uppercase bg-light">
                        <tr>
                            <th class="ps-3 border-0">Student</th>
                            <th class="border-0">Project Title</th>
                            <th class="border-0">Supervisor</th>
                            <th class="border-0">Research Area</th>
                            <th class="text-end pe-3 border-0">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold">@item.StudentName</td>
                                    <td>@item.ProjectTitle</td>
                                    <td class="text-muted">@item.SupervisorName</td>
                                    <td><span class="tag m-0 border-0 text-muted">@item.ResearchArea</span></td>
                                    <td class="text-end pe-3">
                                        <span class="badge @(item.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark") shadow-sm">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">No matches currently in the system.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-box">
            <h5 class="fw-bold mb-4"><i class="bi bi-tags me-2"></i>Research Area Management</h5>
            <form asp-controller="Admin" asp-action="AddResearchArea" method="post">
                <div class="input-group mb-4 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                    <input type="text" name="NewArea" class="form-control border-0 bg-light" placeholder="Type a new research area..." required>
                    <button class="btn btn-custom px-4 fw-bold" type="submit">Add Area</button>
                </div>
            </form>
            <div class="d-flex flex-wrap gap-2">
                @if (ViewBag.CurrentTags != null)
                {
                    @foreach (var tagItem in (List<string>)ViewBag.CurrentTags)
                    {
                        <div class="tag shadow-sm d-flex align-items-center m-0">
                            <span class="fw-medium">@tagItem</span>
                            <form asp-controller="Admin" asp-action="RemoveResearchArea" asp-route-areaName="@tagItem" method="post" class="d-inline m-0 p-0 ms-2">
                                <button type="submit" class="btn-close" style="font-size: 10px;" aria-label="Remove"></button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.body.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>
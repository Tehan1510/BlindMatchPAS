@{
    ViewData["Title"] = "System Settings";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body data-theme="light">
    <div class="sidebar">
        <h3><i class="bi bi-stack me-2"></i>PAS</h3>
        <ul>
            <li><a asp-controller="Admin" asp-action="Admin"><i class="bi bi-house-door me-2"></i> Dashboard</a></li>
            <li><a asp-controller="Admin" asp-action="Students"><i class="bi bi-people me-2"></i> Students</a></li>
            <li><a asp-controller="Admin" asp-action="Supervisors"><i class="bi bi-mortarboard me-2"></i> Supervisors</a></li>
            <li><a asp-controller="Admin" asp-action="Matches"><i class="bi bi-folder-check me-2"></i> Matches</a></li>
            <li><a asp-controller="Admin" asp-action="Research"><i class="bi bi-journal-text me-2"></i> Research</a></li>
            <li class="px-3"><hr style="border-top: 1px solid rgba(255,255,255,0.1);"></li>
            <li><a asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i> Settings</a></li>
        </ul>
    </div>
    <header class="topbar">
        <input type="text" class="form-control" style="max-width: 350px; border-radius: 20px;" placeholder="Search..." />
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-pill">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </div>
    </header>
    <main class="main-content">
        <div class="card-box mx-auto" style="max-width: 900px;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold m-0"><i class="bi bi-gear me-2"></i> System Configuration</h3>
                <div class="form-check form-switch d-flex align-items-center">
                    <input class="form-check-input" type="checkbox" id="darkModeToggle">
                    <label class="ms-2 fw-bold small text-muted" for="darkModeToggle">DARK MODE</label>
                </div>
            </div>
            <div class="alert alert-info border-0 rounded-3">
                <i class="bi bi-info-circle me-2"></i>
                <strong>System Info:</strong> Blind-Match PAS is running on <strong>ASP.NET Core 8.0</strong> with <strong>SQL Server (LocalDB)</strong>.
            </div>
            <div class="row g-4 mt-2">
                <div class="col-md-6">
                    <div class="card-box border">
                        <h6 class="fw-bold"><i class="bi bi-people me-2 text-success"></i>User Statistics</h6>
                        <p class="text-muted mb-1">Total Students: <strong>@ViewBag.TotalStudents</strong></p>
                        <p class="text-muted mb-1">Total Supervisors: <strong>@ViewBag.TotalSupervisors</strong></p>
                        <p class="text-muted mb-0">Total Matches: <strong>@ViewBag.TotalMatches</strong></p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-box border">
                        <h6 class="fw-bold"><i class="bi bi-folder me-2 text-success"></i>Project Statistics</h6>
                        <p class="text-muted mb-1">Total Projects: <strong>@ViewBag.TotalProjects</strong></p>
                        <p class="text-muted mb-1">Pending Projects: <strong>@ViewBag.PendingProjects</strong></p>
                        <p class="text-muted mb-0">Matched Projects: <strong>@ViewBag.MatchedProjects</strong></p>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const toggle = document.getElementById('darkModeToggle');
        if (localStorage.getItem('theme') === 'dark') toggle.checked = true;
        toggle.addEventListener('change', () => {
            if (toggle.checked) {
                document.body.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            } else {
                document.body.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
            }
        });
    </script>
</body>
</html>
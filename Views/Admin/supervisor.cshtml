@{
    ViewData["Title"] = "Supervisor Faculty";
}

<div class="card-box">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h3 class="fw-bold m-0"><i class="bi bi-mortarboard me-2"></i> Supervisor Faculty</h3>
            <p class="text-muted small mt-1">Manage faculty workload and research expertise</p>
        </div>
        <button class="btn btn-custom px-4 py-2" data-bs-toggle="modal" data-bs-target="#addSupModal">+ Assign Supervisor</button>
    </div>

    <div class="row">
        
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card sup-card p-4 h-100 border-0 shadow-sm">
                <h5 class="fw-bold mb-1">Dr. Aruna Pathirana</h5>
                <p class="text-muted small mb-4 border-bottom pb-3">Faculty of Computing</p>

                <div class="mb-4">
                    <label class="small fw-bold d-block mb-2 text-muted">Expertise:</label>
                    <div class="d-flex flex-wrap gap-1">
                        <span class="expertise-pill border-0 bg-primary bg-opacity-10 text-primary">Artificial Intelligence</span>
                        <span class="expertise-pill border-0 bg-primary bg-opacity-10 text-primary">Machine Learning</span>
                    </div>
                </div>

                <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small fw-bold">Workload</span>
                        <span class="small text-muted">3 / 5</span>
                    </div>
                    <div class="progress mb-4" style="height: 6px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 60%"></div>
                    </div>
                    <button class="btn btn-outline-secondary w-100 fw-bold py-2 small">View Profile</button>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card sup-card p-4 h-100 border-0 shadow-sm">
                <h5 class="fw-bold mb-1">Prof. Samantha Perera</h5>
                <p class="text-muted small mb-4 border-bottom pb-3">Software Engineering</p>

                <div class="mb-4">
                    <label class="small fw-bold d-block mb-2 text-muted">Expertise:</label>
                    <div class="d-flex flex-wrap gap-1">
                        <span class="expertise-pill border-0 bg-primary bg-opacity-10 text-primary">Cyber Security</span>
                        <span class="expertise-pill border-0 bg-primary bg-opacity-10 text-primary">Cloud Computing</span>
                    </div>
                </div>

                <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="small fw-bold">Workload</span>
                        <span class="small text-muted">4 / 4</span>
                    </div>
                    <div class="progress mb-4" style="height: 6px;">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: 100%"></div>
                    </div>
                    <button class="btn btn-outline-secondary w-100 fw-bold py-2 small">View Profile</button>
                </div>
            </div>
        </div>

    </div>
</div>
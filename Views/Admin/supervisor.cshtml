@model IEnumerable<BlindMatchPAS.Models.UserManagementViewModel>
@{
    ViewData["Title"] = "Supervisor Faculty";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body data-theme="light">
    <div class="sidebar">
        <h3><i class="bi bi-stack me-2"></i>PAS</h3>
        <ul>
            <li><a asp-controller="Admin" asp-action="Admin"><i class="bi bi-house-door me-2"></i> Dashboard</a></li>
            <li><a asp-controller="Admin" asp-action="Students"><i class="bi bi-people me-2"></i> Students</a></li>
            <li><a asp-controller="Admin" asp-action="Supervisors"><i class="bi bi-mortarboard me-2"></i> Supervisors</a></li>
            <li><a asp-controller="Admin" asp-action="Matches"><i class="bi bi-folder-check me-2"></i> Matches</a></li>
            <li><a asp-controller="Admin" asp-action="Research"><i class="bi bi-journal-text me-2"></i> Research</a></li>
            <li class="px-3"><hr style="border-top: 1px solid rgba(255,255,255,0.1);"></li>
            <li><a asp-controller="Admin" asp-action="Settings"><i class="bi bi-gear me-2"></i> Settings</a></li>
        </ul>
    </div>
    <header class="topbar">
        <input type="text" class="form-control" style="max-width: 350px; border-radius: 20px;" placeholder="Search..." />
        <div class="d-flex align-items-center gap-3">
            <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-pill">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </a>
        </div>
    </header>
    <main class="main-content">
        <div class="card-box">
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h3 class="fw-bold m-0"><i class="bi bi-mortarboard me-2"></i> Supervisor Faculty</h3>
                    <p class="text-muted small mt-1">Manage faculty workload and research expertise</p>
                </div>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model != null && Model.Any())
            {
                <div class="row">
                    @foreach (var supervisor in Model)
                    {
                        <div class="col-xl-4 col-md-6 mb-4">
                            <div class="card sup-card p-4 h-100 border-0 shadow-sm">
                                <h5 class="fw-bold mb-1">@supervisor.FullName</h5>
                                <p class="text-muted small mb-4 border-bottom pb-3">@supervisor.Email</p>
                                <div class="mt-auto">
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-calendar me-1"></i>
                                        Registered: @supervisor.CreatedAt.ToString("yyyy-MM-dd")
                                    </p>
                                    <form asp-controller="Admin" asp-action="DeleteUser" asp-route-id="@supervisor.Id" method="post" class="d-inline mt-2">
                                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold py-2 small mt-2"
                                                onclick="return confirm('Are you sure you want to remove this supervisor?')">
                                            Remove Supervisor
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                    <h5 class="text-muted mt-3">No Supervisors Registered Yet</h5>
                </div>
            }
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.body.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>
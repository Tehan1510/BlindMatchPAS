@{ 
    ViewData["Title"] = "Loading..."; 
    Layout = null; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            /* Matches your login page background perfectly */
            background-color: #1e2532; 
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
        }
        
        .splash-content {
            text-align: center;
            animation: fadeIn 1s ease-in-out;
        }
        
        .logo-container {
            background: white;
            width: 110px;
            height: 110px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px auto;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
            /* This makes the logo gently throb */
            animation: pulse 2s infinite ease-in-out; 
        }

        /* The Loading Bar Track */
        .progress-container {
            width: 260px;
            height: 6px;
            background-color: rgba(255,255,255,0.1);
            border-radius: 10px;
            margin: 40px auto 0 auto;
            overflow: hidden;
        }

        /* The Green Loading Bar Fill */
        .progress-bar-custom {
            height: 100%;
            width: 0%;
            background-color: #00a651; /* Your signature PAS green */
            border-radius: 10px;
            /* Fills up over exactly 3 seconds */
            animation: loadBar 3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
        }

        /* Animations */
        @@keyframes loadBar {
            0% { width: 0%; }
            40% { width: 45%; }
            70% { width: 80%; }
            100% { width: 100%; }
        }

        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="splash-content">
        <div class="logo-container">
            <i class="bi bi-stack text-success" style="font-size: 3.5rem;"></i>
        </div>
        
        <h3 class="fw-bold text-white mb-1">Blind-Match PAS</h3>
        <p class="text-muted small" style="opacity: 0.7;">Initializing Secure Environment...</p>

        <div class="progress-container">
            <div class="progress-bar-custom"></div>
        </div>
    </div>

    <script>
        // Once the 3-second animation is done, smoothly redirect to the Welcome page!
        setTimeout(function() {
            window.location.href = '@Url.Action("Index", "Home")';
        }, 3200); // 3200ms gives a tiny pause after the bar hits 100% before redirecting
    </script>

</body>
</html>
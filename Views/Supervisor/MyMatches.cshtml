@model IEnumerable<BlindMatchPAS.Models.Entities.Match>
@{
    ViewData["Title"] = "My Matches";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .dashboard-container { background-color: #f4f5f7; min-height: 100vh; }
        .sidebar {
            background-color: #1e2532;
            min-height: 100vh;
            color: white;
            padding-top: 2rem;
        }
        .filter-btn {
            color: #a0aec0;
            text-align: left;
            padding: 10px 20px;
            border-radius: 8px;
            margin-bottom: 5px;
            transition: 0.2s;
            display: block;
            text-decoration: none;
        }
        .filter-btn:hover { background-color: rgba(255,255,255,0.1); color: white; }
        .filter-btn.active {
            background-color: #242c3d;
            color: white;
            border-left: 4px solid #00a651;
            font-weight: bold;
        }
    </style>
</head>
<body>
<div class="container-fluid dashboard-container p-0">
    <div class="row g-0">

        @* SIDEBAR *@
        <div class="col-md-3 col-lg-2 sidebar px-3">
            <h4 class="fw-bold mb-4 px-2">
                <i class="bi bi-stack text-success"></i> PAS
            </h4>
            <h6 class="text-uppercase text-muted small fw-bold mb-3 px-2">Navigation</h6>
            <div class="d-flex flex-column">
                <a asp-controller="Supervisor" asp-action="Index" class="filter-btn">
                    <i class="bi bi-grid-1x2 me-2"></i> Dashboard
                </a>
                <a asp-controller="Supervisor" asp-action="MyMatches" class="filter-btn active">
                    <i class="bi bi-folder-check me-2"></i> My Matches
                </a>
                <a asp-controller="Supervisor" asp-action="Settings" class="filter-btn">
                    <i class="bi bi-gear me-2"></i> Settings
                </a>
                <a asp-controller="Account" asp-action="Logout" class="filter-btn" style="color: #fc8181;">
                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                </a>
            </div>
        </div>

        @* MAIN CONTENT *@
        <div class="col-md-9 col-lg-10 p-5">
            <div class="mb-5">
                <h2 class="fw-bold mb-0">My Confirmed Matches</h2>
                <p class="text-muted">Students you have accepted for supervision.</p>
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <h5 class="text-muted mt-3">No Matches Yet</h5>
                    <p class="text-muted small">You have not confirmed any project supervisions yet.</p>
                    <a asp-controller="Supervisor" asp-action="Index" class="btn btn-pas-green rounded-pill px-4 mt-2 fw-bold">
                        Browse Proposals
                    </a>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="text-muted small text-uppercase bg-light">
                                <tr>
                                    <th class="ps-3 border-0">#</th>
                                    <th class="border-0">Project Title</th>
                                    <th class="border-0">Student Name</th>
                                    <th class="border-0">Student Email</th>
                                    <th class="border-0">Research Area</th>
                                    <th class="border-0">Matched On</th>
                                    <th class="text-end pe-3 border-0">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int i = 1; }
                                @foreach (var match in Model)
                                {
                                    <tr>
                                        <td class="ps-3 text-muted fw-bold">#@(i++)</td>
                                        <td class="fw-bold">@match.Project.Title</td>
                                        <td>@match.Project.StudentProfile.User.FullName</td>
                                        <td class="text-muted">@match.Project.StudentProfile.User.Email</td>
                                        <td>
                                            <span class="badge bg-light text-dark border">
                                                @match.Project.ResearchArea
                                            </span>
                                        </td>
                                        <td class="text-muted">@match.MatchedAt.ToString("yyyy-MM-dd")</td>
                                        <td class="text-end pe-3">
                                            <span class="badge bg-success">@match.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
@model IEnumerable<BlindMatchPAS.Models.ProjectViewModel>
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
    var activeFilter = ViewBag.ActiveFilter as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .dashboard-container { background-color: #f4f5f7; min-height: 100vh; }
        .sidebar { 
            background-color: #1e2532; 
            min-height: 100vh; 
            color: white; 
            padding-top: 2rem; 
        }
        .filter-btn { 
            color: #a0aec0; 
            text-align: left; 
            padding: 10px 20px; 
            border-radius: 8px; 
            margin-bottom: 5px; 
            transition: 0.2s; 
            display: block; 
            text-decoration: none; 
        }
        .filter-btn:hover { background-color: rgba(255,255,255,0.1); color: white; }
        .filter-btn.active { 
            background-color: #242c3d; 
            color: white; 
            border-left: 4px solid #00a651; 
            font-weight: bold; 
        }
    </style>
</head>
<body>
<div class="container-fluid dashboard-container p-0">
    <div class="row g-0">

        @* ===== SIDEBAR ===== *@
        <div class="col-md-3 col-lg-2 sidebar px-3">
            <h4 class="fw-bold mb-4 px-2">
                <i class="bi bi-stack text-success"></i> PAS
            </h4>
            <h6 class="text-uppercase text-muted small fw-bold mb-3 px-2">
                Expertise Filters
            </h6>
            <div class="d-flex flex-column">
                <a asp-action="Index" asp-route-expertise="All" 
                   class="filter-btn @(activeFilter == "All" ? "active" : "")">
                    <i class="bi bi-grid-1x2 me-2"></i> All Proposals
                </a>
                <a asp-action="Index" asp-route-expertise="AI" 
                   class="filter-btn @(activeFilter == "AI" ? "active" : "")">
                    <i class="bi bi-cpu me-2"></i> AI
                </a>
                <a asp-action="Index" asp-route-expertise="Software" 
                   class="filter-btn @(activeFilter == "Software" ? "active" : "")">
                    <i class="bi bi-window me-2"></i> Software
                </a>
                <a asp-action="Index" asp-route-expertise="Java" 
                   class="filter-btn @(activeFilter == "Java" ? "active" : "")">
                    <i class="bi bi-cup-hot me-2"></i> Java
                </a>
                <a asp-action="Index" asp-route-expertise="C#" 
                   class="filter-btn @(activeFilter == "C#" ? "active" : "")">
                    <i class="bi bi-code-slash me-2"></i> C#
                </a>
            </div>
        </div>

        @* ===== MAIN CONTENT ===== *@
        <div class="col-md-9 col-lg-10 p-5">

            @* Top bar *@
            <div class="d-flex justify-content-between align-items-center mb-5">
                <div>
                    <h2 class="fw-bold mb-0">Blind Review</h2>
                    <p class="text-muted">
                        Viewing category: 
                        <strong class="text-success">@activeFilter</strong>
                    </p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-white px-3 py-2 rounded-pill shadow-sm border d-none d-md-block">
                        <i class="bi bi-eye-slash-fill text-muted me-2"></i>
                        <span class="fw-bold text-dark small">Identity Hidden</span>
                    </div>

                    @* User dropdown *@
                    <div class="dropdown">
                        <button class="btn btn-light bg-white border shadow-sm rounded-pill px-3 py-2 dropdown-toggle d-flex align-items-center gap-2" 
                                type="button" 
                                data-bs-toggle="dropdown" 
                                aria-expanded="false">
                            <div class="bg-success rounded-circle text-white d-flex align-items-center justify-content-center" 
                                 style="width: 28px; height: 28px;">
                                <i class="bi bi-person-fill small"></i>
                            </div>
                            <span class="fw-bold text-dark small">
                                @ViewBag.SupervisorName
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-2">
                            <li>
                                <a class="dropdown-item py-2 text-dark" 
                                   asp-controller="Supervisor" 
                                   asp-action="Settings">
                                    <i class="bi bi-gear text-muted me-2"></i> Settings
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                @* Real logout now - goes to Account/Logout *@
                                <a class="dropdown-item py-2 text-danger fw-bold" 
                                   asp-controller="Account" 
                                   asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            @* Success message after confirming a match *@
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <strong>Success!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Error message if match failed *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                    <strong>Error!</strong> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @* Project cards grid *@
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <h5 class="text-muted mt-3">No proposals found</h5>
                    <p class="text-muted small">
                        There are no projects in this category yet.
                    </p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var project in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="card h-100 border-0 shadow-sm rounded-4 p-2 project-card-custom">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <span class="badge bg-light text-dark border">
                                            @project.ResearchArea
                                        </span>
                                        <span class="text-muted small">
                                            Project #@project.Id
                                        </span>
                                    </div>
                                    <h5 class="fw-bold text-dark mb-3">@project.Title</h5>
                                    <p class="text-muted small mb-4 flex-grow-1">
                                        @project.Abstract
                                    </p>
                                    <div class="mt-auto border-top pt-3">
                                        <a asp-action="Details" asp-route-id="@project.Id" 
                                           class="btn btn-outline-dark w-100 fw-bold rounded-pill">
                                            <i class="bi bi-file-earmark-text me-2"></i> 
                                            Read Proposal
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
@using BlindMatchPAS.Models
@model ProjectViewModel

@{
    ViewBag.Title = "Confirm Match";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-success">
                <div class="card-header bg-success text-white text-center">
                    <h4>Match Confirmation</h4>
                </div>
                <div class="card-body p-5 text-center">
                    <h5>Project: <strong>@Model.Title</strong></h5>
                    <p class="text-warning mt-3">
                        ⚠️ Confirming this will trigger the <strong>Identity Reveal</strong>.<br>
                        Both you and the student will see each other’s details.
                    </p>

                    <form asp-action="Confirm" method="post">
                        <input type="hidden" name="ProjectId" value="@Model.Id" />
                        <button type="submit" class="btn btn-success btn-lg w-100 mt-4">✅ Yes, Confirm Match</button>
                    </form>
                    <a href="/Supervisor" class="btn btn-outline-secondary btn-lg w-100 mt-2">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>
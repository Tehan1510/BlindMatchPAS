@{ ViewData["Title"] = "Account Settings"; Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PAS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .dashboard-container { background-color: #f4f5f7; min-height: 100vh; }
        .sidebar { background-color: #1e2532; min-height: 100vh; color: white; padding-top: 2rem; }
        .filter-btn { color: #a0aec0; text-align: left; padding: 10px 20px; border-radius: 8px; margin-bottom: 5px; transition: 0.2s; display: block; text-decoration: none; }
        .filter-btn:hover { background-color: rgba(255,255,255,0.1); color: white; }
    </style>
</head>
<body>
<div class="container-fluid dashboard-container p-0">
    <div class="row g-0">
        <div class="col-md-3 col-lg-2 sidebar px-3">
            <h4 class="fw-bold mb-4 px-2"><i class="bi bi-stack text-success"></i> PAS</h4>
            <h6 class="text-uppercase text-muted small fw-bold mb-3 px-2">Navigation</h6>
            <div class="d-flex flex-column">
                <a asp-action="Index" class="filter-btn"><i class="bi bi-grid-1x2 me-2"></i> Dashboard</a>
                <a asp-action="Settings" class="filter-btn" style="background-color: #242c3d; color: white; border-left: 4px solid #00a651; font-weight: bold;"><i class="bi bi-gear me-2"></i> Settings</a>
            </div>
        </div>
        <div class="col-md-9 col-lg-10 p-5">
            <div class="mb-5">
                <h2 class="fw-bold mb-0">Settings & Preferences</h2>
                <p class="text-muted">Manage your account details and supervision criteria.</p>
            </div>
            <div class="row">
                <div class="col-xl-8">
                    <form asp-action="Settings" method="post">
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4"><i class="bi bi-person-badge text-success me-2"></i> Professional Profile</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Full Name</label>
                                        <input type="text" class="form-control bg-light" value="Dr. Supervisor Name" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Faculty / Department</label>
                                        <select class="form-select bg-light">
                                            <option selected>Faculty of Computing</option>
                                            <option>Faculty of Business</option>
                                            <option>Faculty of Engineering</option>
                                        </select>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label fw-bold small text-muted">Academic Email</label>
                                        <input type="email" class="form-control bg-light text-muted" value="test@superviouse.ac.nsbm.lk" readonly>
                                        <div class="form-text">Your email cannot be changed as it is tied to the university domain.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4"><i class="bi bi-sliders text-success me-2"></i> Supervision Preferences</h5>
                                <div class="mb-4">
                                    <label class="form-label fw-bold small text-muted">Maximum Project Quota</label>
                                    <input type="number" class="form-control bg-light" style="max-width: 150px;" value="5" min="1" max="10">
                                    <div class="form-text">How many groups are you willing to supervise this semester?</div>
                                </div>
                                <label class="form-label fw-bold small text-muted mb-2">Preferred Research Domains (Blind Review)</label>
                                <div class="d-flex flex-wrap gap-3">
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="prefAI" checked>
                                        <label class="form-check-label" for="prefAI">Artificial Intelligence</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="prefSE" checked>
                                        <label class="form-check-label" for="prefSE">Software Engineering</label>
                                    </div>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" role="switch" id="prefNet">
                                        <label class="form-check-label" for="prefNet">Networking & IoT</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-light fw-bold px-4 rounded-pill border">Cancel</a>
                            <button type="submit" class="btn btn-pas-green fw-bold px-5 rounded-pill shadow-sm">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>